{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Portal: Start IIS Express (40001), then attach",
            "type": "clr",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "preLaunchTask": "iisexpress: start Portal (40001)",
            "postDebugTask": "iisexpress: stop Portal (40001)"
        },
        {
            "name": "Portal: Attach to IIS Express",
            "type": "clr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
