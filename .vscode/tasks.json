{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "nuget: restore packages",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\dev\\scripts\\Restore-NuGetPackages.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "build: solution Debug",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\dev\\scripts\\Build-Solution.ps1",
                "-Configuration",
                "Debug",
                "-Platform",
                "Any CPU"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "dependsOn": [
                "nuget: restore packages"
            ]
        },
        {
            "label": "iisexpress: start Portal (40001)",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\dev\\scripts\\Start-IISExpress.ps1",
                "-Port",
                "40001"
            ],
            "isBackground": false,
            "problemMatcher": []
        },
        {
            "label": "iisexpress: stop Portal (40001)",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\dev\\scripts\\Stop-IISExpress.ps1",
                "-Port",
                "40001"
            ],
            "problemMatcher": []
        },
        {
            "label": "iisexpress: restart Portal (40001)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "iisexpress: stop Portal (40001)",
                "iisexpress: start Portal (40001)"
            ],
            "problemMatcher": []
        },
        {
            "label": "gulp: assets:build",
            "type": "npm",
            "script": "assets:build",
            "path": "src/Portal",
            "problemMatcher": []
        },
        {
            "label": "gulp: startWatch",
            "type": "npm",
            "script": "assets:watch",
            "path": "src/Portal",
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "gulp: stopWatch",
            "type": "npm",
            "script": "assets:stop-watch",
            "path": "src/Portal",
            "problemMatcher": []
        },
        {
            "label": "portal: build assets and start",
            "dependsOrder": "sequence",
            "dependsOn": [
                "build: solution Debug",
                "gulp: assets:build",
                "iisexpress: start Portal (40001)"
            ],
            "problemMatcher": []
        },
        {
            "label": "portal: smoke (running site)",
            "type": "process",
            "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
            "args": [
                "-NoLogo",
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\dev\\scripts\\Test-PortalSmoke.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "portal: extension smoke (running site)",
            "type": "process",
            "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
            "args": [
                "-NoLogo",
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\dev\\scripts\\Test-PortalExtensionSmoke.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "portal: documentation baseline",
            "type": "process",
            "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
            "args": [
                "-NoLogo",
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\dev\\scripts\\Get-PortalDocumentationBaseline.ps1",
                "-AsJson"
            ],
            "problemMatcher": []
        },
        {
            "label": "portal: build JavaScript documentation pilot",
            "type": "process",
            "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
            "args": [
                "-NoLogo",
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\dev\\scripts\\Build-PortalJsdocPilot.ps1"
            ],
            "problemMatcher": []
        }
    ]
}
