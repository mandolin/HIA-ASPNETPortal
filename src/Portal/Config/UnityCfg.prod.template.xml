<?xml version='1.0' encoding='utf-8'?>
<configuration>
    <configSections>
        <section name='unity' type='Microsoft.Practices.Unity.Configuration.UnityConfigurationSection, Unity.Configuration' />
    </configSections>

    <unity xmlns="http://schemas.microsoft.com/practices/2010/unity">
        <!--定义Unity配置的命名空间和需要扫描的程序集，指示Unity将会在指定的程序集中查找类型进行注册和依赖注入。-->
        <namespace name="ASPNET.StarterKit.Portal" />
        <assembly name="Portal" />
        <assembly name="Portal.Components" />
        <assembly name="Portal.Components.Data" />
        <assembly name="Portal.Components.Data1" />

        <container>

            <!-- connectionString 由启动代码从外置 connectionStrings.config 加载，本文件不保存真实连接串。 -->

            <instance name="testStr" type="string"
                      value="prod UnityCfg" />

        </container>
    </unity>
</configuration>


