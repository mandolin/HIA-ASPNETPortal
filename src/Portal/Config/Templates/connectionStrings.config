<?xml version="1.0" encoding="utf-8"?>
<connectionStrings>
    <!--
    这是外置连接串模板，只用于复制到仓库外目录后再填写真实值。
    当前代码读取 name="Portal" 的连接串，并在启动时映射为 Unity 的 connectionString 命名实例。
    -->
    <add name="Portal"
         connectionString="Data Source=(localdb)\MSSQLLocalDB;Integrated Security=True;Initial Catalog=Portal; MultipleActiveResultSets=True"
         providerName="System.Data.SqlClient" />
</connectionStrings>
