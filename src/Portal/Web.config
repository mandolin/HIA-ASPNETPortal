<?xml version="1.0" encoding="utf-8"?>
<!--注意: 除了手动编辑此文件以外，您还可以使用 Web 管理工具来配置应用程序的设置。可以使用 Visual Studio 中的“网站”->“Asp.Net 配置”选项。-->

<!--#note 多配置机制

    appSettings 会在启动时读取基础 json 和当前 env 对应的 json。
    connectionStrings 保留为空，真实连接串由 Application_Start 从外置 connectionStrings.config 加载。
    其它配置则通过 Web.config Transformations 机制进行(与环境对应的)配置，并只能在启动时加载。
-->

<!--configuration 是 web.config 文件的根元素。-->
<configuration>
    <!--configSections 指定配置节和命名空间声明。clear:移除对继承的节和节组的所有引用，只允许由当前 section 和 sectionGroup 元素添加的节和节组。remove:移除对继承的节和节组的引用。-->
    <!--section 定义配置节处理程序与配置元素之间的关联。sectionGroup:定义配置节处理程序与配置节之间的关联。-->
    <configSections>
        <section name="unity" type="Microsoft.Practices.Unity.Configuration.UnityConfigurationSection, Unity.Configuration" />
        <section name="env" type="ASPNET.StarterKit.Portal.Sys.EnvSection, Portal" />
    </configSections>

    <!-- the file is copied by the build environment but it is not added to the project -->
    <unity configSource="Config\UnityCfg.xml" />

    <!-- 环境标识：dev|test|prod -->
    <env value="dev" />
    <!--
    For a description of web.config changes see http://go.microsoft.com/fwlink/?LinkId=235367.

    The following attributes can be set on the <httpRuntime> tag.
      <system.Web>
        <httpRuntime targetFramework="4.5.1" />
      </system.Web>
    -->
    <!--system.web 配置与 ASP.NET 应用程序有关的各种设置，包括身份验证、授权、会话状态、HTTP运行时、编译、自定义错误页面等-->
    <system.web>
        <!--#Dev# #Prod# 注意：生产环境中建议将此句改为 requireSSL="true"-->
        <httpCookies requireSSL="false" />
        <httpRuntime targetFramework="4.7" maxRequestLength="30720" executionTimeout="300" />

        <!--
            Set compilation debug="true" to insert debugging
            symbols into the compiled page. Because this
            affects performance, set this value to true only
            during development.
        -->
        <!--#Dev# #Prod# 注意：生产环境中建议改为 debug="false"-->
        <compilation debug="true" targetFramework="4.7" />
        <!--The Portal Starter Kit supports either Forms authentication (Internet)
            or Windows authentication (for intranets).  Forms Authentication is
            the default.  To change to Windows authentication, comment the
            <authentication mode="Forms"> section below, and uncomment the
            <authentication mode="Windows"> section. -->

        <!--authentication 身份验证配置-->
        <authentication mode="Forms">
            <forms name=".ASPXAUTH" protection="All" timeout="60" />
        </authentication>
        <!--
        <authentication mode="Windows" />
        -->

        <!--authorization 授权规则配置-->
        <!--
        <authorization>
            <deny users="?" />
        </authorization>
        -->

        <!--customErrors 自定义错误展示配置-->
        <!--
            The <customErrors> section enables configuration
            of what to do if/when an unhandled error occurs
            during the execution of a request. Specifically,
            it enables developers to configure html error pages
            to be displayed in place of a error stack trace.

        -->
        <customErrors mode="RemoteOnly" defaultRedirect="GenericErrorPage.aspx" />

        <globalization culture="zh-cn" uiCulture="zh-cn" />

        <pages controlRenderingCompatibilityVersion="3.5" clientIDMode="AutoID" theme="Default" />
    </system.web>

    <!--connectionStrings 保留为空；真实连接串由 Application_Start 从外置 connectionStrings.config 加载。-->
    <connectionStrings>
        <!-- 不在仓库内保存真实数据库连接字符串。 -->
    </connectionStrings>

    <!--appSettings 用于配置应用程序级别的自定义配置项，例如密钥、API 地址等。可以在代码中通过ConfigurationManager.AppSettings来读取这些值-->
    <appSettings>
        <!-- 应用程序级别的配置项 -->
        <!--
        可选：覆盖外置配置根目录。
        留空时默认使用当前进程用户目录\Web\HIA-ASPNETPortal\，
        连接串文件再按当前 env 进入 dev/test/prod 子目录读取。
        -->
        <add key="ExternalCfgPath" value="" />
        <!-- 当前门户主题；为空、非法或目录缺失时回退 Default。 -->
        <add key="Portal.Theme.Name" value="Default" />
        <!-- 诊断日志目录；留空时使用 App_Data\Logs，可在生产环境中覆盖到外置目录。 -->
        <add key="Portal.Diagnostics.LogDirectory" value="" />
        <!-- 开发期详细错误输出开关；生产环境不应开启，后续会升级为受控权限查看。 -->
        <add key="Portal.Diagnostics.EnableDetailedErrors" value="false" />
        <add key="Portal.Documents.MaxUploadBytes" value="10485760" />
        <!-- 默认不开放自主注册；后续系统管理模块会扩展审核和临时注册链接。 -->
        <add key="Portal.Security.AllowSelfRegistration" value="false" />
        <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
    </appSettings>

    <!--
        The system.webServer section is required for running ASP.NET AJAX under Internet
        Information Services 7.0.  It is not necessary for previous version of IIS.
    -->
    <!--system.webServer 配置在 IIS 服务器上运行的应用程序的一些设置，例如处理静态文件、HTTP 访问控制、URL重写、重定向等。-->
    <system.webServer>
        <security>
            <requestFiltering>
                <requestLimits maxAllowedContentLength="31457280" />
            </requestFiltering>
        </security>
        <httpProtocol>
            <customHeaders>
                <!--
                    以下是针对企业项目漏洞检测（比如绿盟）的一些设置
                -->
                <!--针对：检测到目标X-Content-Type-Options响应头缺失。作用：防止内容嗅探-->
                <add name="X-Content-Type-Options" value="nosniff" />
                <!--针对：检测到目标X-XSS-Protection响应头缺失。作用：防止XSS攻击-->
                <add name="X-XSS-Protection" value="1;mode=block" />
                <!--针对：检测到目标Content-Security-Policy响应头缺失-->
                <add name="Content-Security-Policy" value="default-src 'self' 'unsafe-inline' 'unsafe-eval'" />
                <!--针对：检测到目标Strict-Transport-Security响应头缺失。作用：强制浏览器只能通过 HTTPS 访问网站-->
                <add name="Strict-Transport-Security" value="max-age=31536000" />
                <!--针对：检测到目标Referrer-Policy响应头缺失-->
                <add name="Referrer-Policy" value="origin-when-cross-origin" />
                <!--针对：检测到目标X-Permitted-Cross-Domain-Policies响应头缺失-->
                <add name="X-Permitted-Cross-Domain-Policies" value="master-only" />
                <!--针对：检测到目标X-Download-Options响应头缺失-->
                <add name="X-Download-Options" value="noopen" />
                <!--针对：点击劫持：X-Frame-Options未配置。作用：防止点击劫持攻击-->
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                <!--一些跨域设置-->
                <!--
                <add name="Access-Control-Allow-Origin" value="*" />
                <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, OPTIONS" />
                <add name="Access-Control-Allow-Headers" value="Content-Type" />
                -->
                <!--一些缓存设置-->
                <!--
                <add name="Cache-Control" value="no-cache, no-store" />
                <add name="Pragma" value="no-cache" />
                <add name="Expires" value="-1" />
                -->
            </customHeaders>
        </httpProtocol>
    </system.webServer>

    <!--system.serviceModel 用于定义和配置 Windows Communication Foundation (WCF) 服务的行为、终结点、协议和其他相关设置。-->
    <system.serviceModel>
        <serviceHostingEnvironment aspNetCompatibilityEnabled="true" />
    </system.serviceModel>

    <!--runtime 配置运行时行为，例如内存管理、程序集绑定等。-->
    <runtime>
        <!--assemblyBinding 用于配置 .NET 程序集绑定策略。它允许你在运行时控制程序集加载和版本管理-->
        <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
            <!--dependentAssembly 为<assemblyBinding> 中的主要子元素，用于定义特定程序集的绑定策略。-->
            <dependentAssembly>
                <assemblyIdentity name="Microsoft.Practices.ServiceLocation" publicKeyToken="31bf3856ad364e35" culture="neutral" />
                <bindingRedirect oldVersion="0.0.0.0-1.3.0.0" newVersion="1.3.0.0" />
            </dependentAssembly>
            <dependentAssembly>
                <assemblyIdentity name="Unity.Abstractions" publicKeyToken="489b6accfaf20ef0" culture="neutral" />
                <bindingRedirect oldVersion="0.0.0.0-5.11.7.0" newVersion="5.11.7.0" />
            </dependentAssembly>
            <dependentAssembly>
                <assemblyIdentity name="Unity.Container" publicKeyToken="489b6accfaf20ef0" culture="neutral" />
                <bindingRedirect oldVersion="0.0.0.0-5.11.11.0" newVersion="5.11.11.0" />
            </dependentAssembly>
            <!-- Json.NET 绑定重定向：统一旧引用到当前安全版本。/ Json.NET binding redirect: unify legacy references on the patched version. -->
            <dependentAssembly>
                <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
                <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
            </dependentAssembly>
        </assemblyBinding>
    </runtime>
</configuration>
